# ─── Required ──────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ─── Admin Configuration ────────────────────────────────────────────────────
# Comma-separated Telegram user IDs of super admins (always have access)
ADMIN_IDS=123456789,987654321

# Group or channel ID to forward registrations/payments (use negative ID for groups)
ADMIN_GROUP_ID=-1001234567890

# Password for admin panel login
ADMIN_PASSWORD=your_secure_password_here

# ─── Force Channel Join (optional) ─────────────────────────────────────────
# Leave empty to disable. Use @username or numeric channel ID
FORCE_JOIN_CHANNEL=@yourchannel

# ─── Database ───────────────────────────────────────────────────────────────
# For SQLite (default, good for Railway):
DATABASE_URL=sqlite+aiosqlite:///interview_bot.db

# For PostgreSQL (Railway provides this):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ─── Payment Settings (can also be changed via admin panel) ─────────────────
DEFAULT_MOCK_PRICE=99.0
DEFAULT_UPI_ID=example@upi
DEFAULT_PAYEE_NAME=Interview Management
PAYMENTS_ENABLED=true

# ─── Payment Timer ──────────────────────────────────────────────────────────
PAYMENT_EXPIRY_MINUTES=30

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_MESSAGES=5
RATE_LIMIT_WINDOW=60

# ─── Auto Backup ────────────────────────────────────────────────────────────
AUTO_BACKUP_INTERVAL_HOURS=24
